# GEMINI_API_KEY: Required for Gemini AI API calls.
# Leave EMPTY in this template — set your real key in .env.local (or via your
# hosting provider's secrets panel). The server detects an empty/missing key
# and returns a helpful "not configured" error instead of forwarding an
# invalid credential to Google.
GEMINI_API_KEY=""

# PORT: The port the Express server listens on.
# Cloud platforms (Render, Railway, Fly, Cloud Run) inject this automatically.
# Defaults to 3000 if unset.
# PORT=3000

# NODE_ENV: Set to "production" for the optimized production build.
# When unset, the server runs in development mode (Vite middleware).
# NODE_ENV=production

# CORS_ALLOWED_ORIGINS: Comma-separated list of origins allowed to call
# the API (e.g. "https://app.example.com,https://staging.example.com").
# When unset, defaults to localhost dev origins.
# CORS_ALLOWED_ORIGINS="https://your-app.example.com"

# LOG_LEVEL: One of trace|debug|info|warn|error (default: info).
# Controls pino structured logging verbosity on the server.
# LOG_LEVEL=info

# SENTRY_DSN: Optional. If set, server-side errors are forwarded to Sentry.
# Leave empty to disable Sentry integration.
# SENTRY_DSN=""

# GEMINI_TIMEOUT_MS: Per-request timeout for Gemini SDK calls (default: 30000).
# GEMINI_TIMEOUT_MS=30000

# GEMINI_MAX_RETRIES: Number of retries for transient Gemini failures (default: 1).
# GEMINI_MAX_RETRIES=1

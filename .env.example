# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PORT: The port the Express server listens on.
# Cloud platforms (Render, Railway, Fly, Cloud Run) inject this automatically.
# Defaults to 3000 if unset.
# PORT=3000

# NODE_ENV: Set to "production" for the optimized production build.
# When unset, the server runs in development mode (Vite middleware).
# NODE_ENV=production

# CORS_ALLOWED_ORIGINS: Comma-separated list of origins allowed to call
# the API (e.g. "https://app.example.com,https://staging.example.com").
# When unset, defaults to localhost dev origins.
# CORS_ALLOWED_ORIGINS="https://your-app.example.com"

# SESSION_SECRET: Secret used to sign anonymous session cookies (S-01).
# When unset, a random ephemeral secret is generated — sessions are
# invalidated on server restart. Set a stable secret in production.
# SESSION_SECRET="your-random-64-char-hex-secret-here"

# TRUST_PROXY_HOPS: Number of trusted proxies in the deployment chain (S-02).
# Required for rate limiting to work behind TLS-terminating load balancers.
# Typically 1 for Render/Railway/Fly/Cloud Run behind a single proxy.
# TRUST_PROXY_HOPS=1
